# Ignore Git internals
.git/
.github/

# Ignore Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.cache/
.tox/
.nox/
.hypothesis/

# Ignore uv lock and cache
.uv/
uv.lock

# Ignore testing artifacts
.pytest_cache/
.coverage
htmlcov/

# Ignore runtime data and downloads (potential token burners)
downloads/
data/
logs/
vpn_configs/

# Ignore databases
*.db
*.db-wal
*.db-shm
*.sqlite

# Ignore IDE settings
.vscode/
.idea/
*.swp
*.swo

# Ignore OS-generated files
.DS_Store

# Ignore web dependencies and builds
node_modules/
web/node_modules/
web/dist/
package-lock.json

# Ignore environment files (sensitive)
.env
.env.*

# Ignore other potentially large or irrelevant files
*.log
*.tmp
*.bak

# AI and analysis tool metadata
.claude/
.codegraph/
